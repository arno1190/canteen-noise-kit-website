# Canonical URL for metadata / Open Graph (production)
NEXT_PUBLIC_SITE_URL=https://canteen-noise-kit-website.vercel.app

# Formspree (or compatible) — set in Vercel Project → Environment Variables
# Order / lead form on /tarifs
NEXT_PUBLIC_FORMSPREE_ORDER_URL=https://formspree.io/f/xxxxxxxx
# Optional: shorter newsletter capture on home (defaults to ORDER URL if unset)
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_URL=https://formspree.io/f/yyyyyyyy
