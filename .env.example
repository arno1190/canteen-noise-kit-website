# Canonical URL for metadata / Open Graph (production)
NEXT_PUBLIC_SITE_URL=https://canteen-noise-kit-website.vercel.app

# Optional: public contact e-mail for mailto when Formspree URLs are not set
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com

# Formspree — set in Vercel → Environment Variables (Production). Use real /f/{id} values;
# placeholder-style IDs are rejected at build time and the site shows a neutral fallback.
NEXT_PUBLIC_FORMSPREE_ORDER_URL=https://formspree.io/f/abcd1234efgh
# Optional: home newsletter (falls back to ORDER URL if unset)
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_URL=https://formspree.io/f/wxyz5678abcd
